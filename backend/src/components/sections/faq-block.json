{
  "collectionName": "components_sections_faq_blocks",
  "info": {
    "displayName": "FAQ Block",
    "description": "Frequently asked questions section. Questions come from the FAQ single type."
  },
  "options": {},
  "attributes": {
    "heading": {
      "type": "string",
      "description": "Section heading, e.g. 'Frequently Asked Questions'."
    },
    "intro": {
      "type": "text",
      "description": "Short paragraph above the questions (optional)."
    },
    "contactEmail": {
      "type": "string",
      "description": "Contact email shown in the intro, e.g. Info@PWRL.com (optional)."
    },
    "theme": {
      "type": "enumeration",
      "enum": ["light", "navy"],
      "default": "light",
      "description": "Colour style: 'light' (white) or 'navy' (dark)."
    },
    "faq": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::faq.faq",
      "description": "Which FAQ list to show (usually the single shared FAQ)."
    }
  }
}
