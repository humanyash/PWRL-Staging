{
  "collectionName": "components_sections_news_items",
  "info": {
    "displayName": "News Item",
    "description": "A press/news card (date + title + link + thumbnail)"
  },
  "options": {},
  "attributes": {
    "date": {
      "type": "string",
      "description": "Display date for the card."
    },
    "title": {
      "type": "string",
      "required": true,
      "description": "Article title."
    },
    "href": {
      "type": "string",
      "required": true,
      "description": "Link to the full article."
    },
    "source": {
      "type": "string",
      "description": "Publisher name (optional)."
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "description": "Card image (optional)."
    }
  }
}
