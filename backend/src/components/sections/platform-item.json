{
  "collectionName": "components_sections_platform_items",
  "info": {
    "displayName": "Platform Item",
    "description": "A brokerage platform link (logo + label + group)"
  },
  "options": {},
  "attributes": {
    "label": {
      "type": "string",
      "required": true,
      "description": "Platform name, e.g. Fidelity."
    },
    "href": {
      "type": "string",
      "required": true,
      "description": "Link to the platform (full https:// address)."
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "description": "Platform logo."
    },
    "group": {
      "type": "enumeration",
      "enum": ["self-directed", "advisor"],
      "default": "self-directed",
      "description": "Which tab this platform belongs to."
    }
  }
}
