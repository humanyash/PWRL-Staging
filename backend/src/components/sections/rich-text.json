{
  "collectionName": "components_sections_rich_texts",
  "info": {
    "displayName": "Rich Text",
    "description": "A flexible prose section with an optional side list of key/value rows."
  },
  "options": {},
  "attributes": {
    "heading": {
      "type": "string",
      "description": "Section heading (optional)."
    },
    "subheading": {
      "type": "text",
      "description": "Supporting line under the heading (optional)."
    },
    "body": {
      "type": "richtext",
      "required": true,
      "description": "Main text. Separate paragraphs with a blank line."
    },
    "headingStyle": {
      "type": "enumeration",
      "enum": ["blue", "dark"],
      "default": "dark",
      "description": "Heading colour: 'blue' (electric blue) or 'dark' (charcoal)."
    },
    "tone": {
      "type": "enumeration",
      "enum": ["light", "panel", "gradient"],
      "default": "light",
      "description": "Background style: 'light', 'panel', or 'gradient' (blue-mint dark band)."
    },
    "ctas": {
      "type": "component",
      "repeatable": true,
      "component": "shared.cta",
      "description": "Optional buttons."
    },
    "sideItems": {
      "type": "component",
      "repeatable": true,
      "component": "shared.key-value",
      "description": "Optional right-column rows (used by the gradient style)."
    }
  }
}
