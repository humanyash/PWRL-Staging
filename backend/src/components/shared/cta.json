{
  "collectionName": "components_shared_ctas",
  "info": {
    "displayName": "CTA",
    "description": "A call-to-action link/button"
  },
  "options": {},
  "attributes": {
    "label": {
      "type": "string",
      "required": true,
      "description": "Button text, e.g. VIEW PORTFOLIO."
    },
    "href": {
      "type": "string",
      "required": true,
      "description": "Where the button goes. Use /page for internal pages or a full https:// address."
    },
    "variant": {
      "type": "enumeration",
      "enum": [
        "primary",
        "secondary",
        "link",
        "underline",
        "mint"
      ],
      "default": "primary",
      "required": true,
      "description": "Button style: primary (solid), secondary (outline), mint (green), link or underline (text link)."
    }
  }
}
