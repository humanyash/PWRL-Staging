{
  "kind": "collectionType",
  "collectionName": "team_members",
  "info": {
    "singularName": "team-member",
    "pluralName": "team-members",
    "displayName": "Team Member",
    "description": "Team members. Supports prose bio OR bullet bio (bioFormat enum)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "role": {
      "type": "string"
    },
    "headshot": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "bioFormat": {
      "type": "enumeration",
      "enum": ["prose", "bullets"],
      "default": "prose",
      "required": true
    },
    "bioProse": {
      "type": "richtext"
    },
    "bioBullets": {
      "type": "json"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
