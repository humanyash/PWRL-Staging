{
  "kind": "collectionType",
  "collectionName": "team_members",
  "info": {
    "singularName": "team-member",
    "pluralName": "team-members",
    "displayName": "Leadership Team",
    "description": "Leadership grid on /vision. Upload a headshot and bio for each person."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "import-export-entries": {
      "idField": "name"
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "role": {
      "type": "string"
    },
    "headshot": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "bioFormat": {
      "type": "enumeration",
      "enum": ["prose", "bullets"],
      "default": "prose",
      "required": true
    },
    "bioProse": {
      "type": "customField",
      "customField": "plugin::ckeditor.CKEditor",
      "options": {
        "preset": "light",
        "output": "HTML",
        "licenseKey": "GPL"
      }
    },
    "bioBullets": {
      "type": "json"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
