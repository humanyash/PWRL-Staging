{
  "kind": "collectionType",
  "collectionName": "board_directors",
  "info": {
    "singularName": "board-director",
    "pluralName": "board-directors",
    "displayName": "Board of Directors",
    "description": "Board grid on /investor-relations. Upload a headshot and bio for each director."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "import-export-entries": {
      "idField": "name"
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "role": {
      "type": "string"
    },
    "headshot": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "bio": {
      "type": "customField",
      "customField": "plugin::ckeditor.CKEditor",
      "options": {
        "preset": "light",
        "output": "HTML",
        "licenseKey": "GPL"
      }
    },
    "independent": {
      "type": "boolean",
      "default": false
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "alsoOnTeam": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::team-member.team-member"
    }
  }
}
