{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "A marketing page (Home, Vision, Fund, etc.). Build the page by adding Sections; each section is a block of content that appears in order."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "description": "Internal page name (also used to build the web address)."
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "description": "Web address for this page (the part after the domain). 'home' is the front page. Changing this changes the page's URL."
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo",
      "description": "Search-engine and social-share settings (page title and description)."
    },
    "sections": {
      "type": "dynamiczone",
      "description": "The content blocks that make up this page, in the order they appear. Add, remove, or drag to reorder.",
      "components": [
        "sections.hero",
        "sections.intro",
        "sections.value-props",
        "sections.philosophy",
        "sections.timeline",
        "sections.stats-block",
        "sections.portfolio-block",
        "sections.team-grid",
        "sections.board-grid",
        "sections.faq-block",
        "sections.process-steps",
        "sections.news-list",
        "sections.document-list",
        "sections.cta-group",
        "sections.pull-quote",
        "sections.stock-info",
        "sections.rich-text",
        "sections.form-block",
        "sections.disclosures",
        "sections.anchor-nav",
        "sections.truths",
        "sections.platform-tabs",
        "sections.education-list",
        "sections.education-grid",
        "sections.events-list"
      ]
    }
  }
}