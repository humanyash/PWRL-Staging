{
  "kind": "collectionType",
  "collectionName": "fund_documents",
  "info": {
    "singularName": "fund-document",
    "pluralName": "fund-documents",
    "displayName": "Fund Documents (PDFs)",
    "description": "PDF list on /investor-relations. Upload the PDF in each entry's File field."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "import-export-entries": {
      "idField": "title"
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "kind": {
      "type": "enumeration",
      "enum": ["prospectus", "factsheet", "annual-report", "semi-annual-report", "shareholder-report", "other"],
      "required": true
    },
    "file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"],
      "required": true
    },
    "effectiveDate": {
      "type": "date"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
