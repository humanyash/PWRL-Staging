{
  "kind": "collectionType",
  "collectionName": "forms",
  "info": {
    "singularName": "form",
    "pluralName": "forms",
    "displayName": "HubSpot Forms",
    "description": "HubSpot portal and form IDs used by contact and newsletter sections on the site."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "label": {
      "type": "string",
      "required": true
    },
    "identifier": {
      "type": "uid",
      "targetField": "label",
      "required": true
    },
    "portalId": {
      "type": "string",
      "required": true
    },
    "formId": {
      "type": "string",
      "required": true
    },
    "theme": {
      "type": "enumeration",
      "enum": ["light", "dark"],
      "default": "light"
    }
  }
}
