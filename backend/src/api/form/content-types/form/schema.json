{
  "kind": "collectionType",
  "collectionName": "forms",
  "info": {
    "singularName": "form",
    "pluralName": "forms",
    "displayName": "Form",
    "description": "HubSpot form references (portalId, formId, identifier, theme)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "identifier": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "portalId": {
      "type": "string",
      "required": true
    },
    "formId": {
      "type": "string",
      "required": true
    },
    "theme": {
      "type": "enumeration",
      "enum": ["light", "dark"],
      "default": "light"
    }
  }
}
